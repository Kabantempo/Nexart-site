{
  "name": "nexart-site",
  "version": "1.2.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "postbuild": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public",
    "build:local": "NEXT_TELEMETRY_DISABLED=1 RAYON_NUM_THREADS=1 NEXT_CPU_CPUS=1 next build",
    "start": "node .next/standalone/server.js",
    "lint": "eslint",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "audit:performance": "node scripts/audit-performance.mjs",
    "bump-version": "bash scripts/bump-version.sh"
  },
  "dependencies": {
    "@21st-sdk/agent": "^0.0.18",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@sentry/nextjs": "^10.66.0",
    "@stripe/stripe-js": "^9.9.0",
    "@supabase/supabase-js": "^2.107.0",
    "@types/leaflet": "^1.9.21",
    "@types/nodemailer": "^8.0.1",
    "@types/web-push": "^3.6.4",
    "autoprefixer": "^10.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "js-cookie": "^3.0.8",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.17.0",
    "next": "^13.5.6",
    "nodemailer": "^9.0.3",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "web-push": "^3.6.7",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "eslint": "^9",
    "eslint-config-next": "^15.5.19",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
